datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

// =====================================================================
// AUTH (better-auth) — kept as-is
// =====================================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]
  clients  Client[]
  projects Project[]
  tasks    Task[]
  invoices Invoice[]
  payments Payment[]
  activity ActivityLog[]
  clientActions ClientAction[]
  meetings      Meeting[]
  linearSyncRuns LinearSyncRun[]
  settings UserSettings?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}

// =====================================================================
// USER SETTINGS — slim version (only what the new design needs)
// =====================================================================

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultCurrency    String  @default("EUR")
  defaultPaymentDays Int     @default(30)
  defaultRate        Decimal @default(0) @db.Decimal(10, 2)

  // Linear integration (AES-256-GCM encrypted)
  linearApiTokenEncrypted   Bytes?
  linearApiTokenIv          Bytes?
  linearApiTokenKeyVersion  Int?      @default(1)
  linearLastSyncedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_settings")
}

// =====================================================================
// CORE DOMAIN
// =====================================================================

enum BillingMode {
  HOURLY
  DAILY
  FIXED
}

enum ClientCategory {
  FREELANCE
  STUDY
  PERSONAL
  SIDE_PROJECT
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  PENDING_INVOICE
  DONE
  CANCELED
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERPAID
}

enum InvoiceKind {
  STANDARD
  DEPOSIT
}

// ---------- Client ----------

model Client {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  company   String?
  email     String?
  phone     String?
  website   String?
  address   String?
  notes     String? @db.Text

  billingMode  BillingMode @default(DAILY)
  rate         Decimal     @default(0) @db.Decimal(10, 2)
  fixedPrice   Decimal?    @db.Decimal(10, 2)
  deposit      Decimal?    @db.Decimal(10, 2)
  paymentTerms Int?

  category ClientCategory @default(FREELANCE)
  color    String?
  starred  Boolean        @default(false)

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  linearMappings LinearMapping[]
  projects       Project[]
  tasks          Task[]
  invoices       Invoice[]
  activity       ActivityLog[]
  clientActions  ClientAction[]
  meetings       Meeting[]

  @@index([userId])
  @@index([userId, archivedAt])
  @@index([category])
  @@map("clients")
}

// ---------- Linear mapping (Client ↔ Linear team or project) ----------
//
// Defines WHICH Linear scope feeds tasks for a given client. Supports either
// a whole Linear team (all its issues) or a specific Linear project.
// At least one of linearTeamId / linearProjectId must be set (enforced via Zod).

model LinearMapping {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  linearTeamId    String?
  linearProjectId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, linearProjectId])
  @@unique([clientId, linearTeamId])
  @@index([linearTeamId])
  @@index([linearProjectId])
  @@map("linear_mappings")
}

// ---------- Project (mirror of a Linear project) ----------
//
// Always backed by a Linear project — never created manually. Auto-populated
// when the Linear sync discovers projects within the user's mapped scopes.

model Project {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  linearProjectId String  @unique
  linearTeamId    String?

  name        String
  key         String
  description String?
  status      ProjectStatus @default(ACTIVE)

  linearCreatedAt DateTime?
  lastSyncedAt    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tasks    Task[]
  invoices Invoice[]
  activity ActivityLog[]

  @@index([userId])
  @@index([userId, status])
  @@index([clientId])
  @@index([status])
  @@map("projects")
}

// ---------- Task (mirror of a Linear issue + billing state) ----------
//
// One row per Linear issue we care about. The display `status` is derived
// during sync from the Linear state's type:
//   - completed + !invoiceId   → PENDING_INVOICE
//   - completed +  invoiceId   → DONE
//   - started                  → IN_PROGRESS
//   - unstarted/triage         → BACKLOG
//   - canceled                 → CANCELED (filtered out of most views)
// We also persist Linear's raw state name + type for display/debugging.

model Task {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  linearIssueId    String  @unique
  linearIdentifier String // e.g. "TRI-543" — displayed in tables
  linearStateName  String?
  linearStateType  String?

  title       String
  description String?      @db.Text
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(NONE)
  estimate    Decimal?     @db.Decimal(6, 2)

  completedAt     DateTime?
  linearCreatedAt DateTime?
  linearUpdatedAt DateTime?
  lastSyncedAt    DateTime  @default(now())

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  invoiceLines InvoiceLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([clientId, status])
  @@index([projectId])
  @@index([invoiceId])
  @@index([invoiceId, userId])
  @@index([status])
  @@index([clientId, lastSyncedAt(sort: Desc)])
  @@map("tasks")
}

// ---------- Invoice ----------

model Invoice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  number        String
  status        InvoiceStatus @default(DRAFT)
  paymentStatus PaymentStatus @default(UNPAID)
  kind          InvoiceKind   @default(STANDARD)

  issueDate DateTime
  dueDate   DateTime

  subtotal      Decimal  @default(0) @db.Decimal(10, 2)
  totalOverride Decimal? @db.Decimal(10, 2)
  tax      Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @default(0) @db.Decimal(10, 2)
  notes    String? @db.Text

  lines    InvoiceLine[]
  files    InvoiceFile[]
  tasks    Task[]
  payments Payment[]
  activity ActivityLog[]
  clientActions ClientAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, number])
  @@index([userId])
  @@index([userId, status, paymentStatus])
  @@index([userId, issueDate(sort: Desc)])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([paymentStatus])
  @@index([issueDate])
  @@map("invoices")
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount Decimal  @db.Decimal(10, 2)
  paidAt DateTime
  method String?
  note   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, paidAt])
  @@index([invoiceId])
  @@index([paidAt])
  @@map("payments")
}

enum ActivityKind {
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_ARCHIVED
  CLIENT_DUPLICATED
  INVOICE_CREATED
  INVOICE_SENT
  INVOICE_CANCELLED
  PAYMENT_RECORDED
  PAYMENT_DELETED
  TASKS_PENDING
  LINEAR_SYNCED
  ACTION_DONE
  MEETING_LOGGED
}

model ActivityLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  kind  ActivityKind
  title String
  meta  String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([clientId, createdAt])
  @@map("activity_log")
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  label    String
  qty      Decimal @db.Decimal(10, 2)
  rate     Decimal @db.Decimal(10, 2)
  position Int     @default(0)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([taskId])
  @@map("invoice_lines")
}

model InvoiceFile {
  id         String   @id @default(cuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fileName   String
  fileSize   Int
  mimeType   String   @default("application/pdf")
  fileData   Bytes
  uploadedAt DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_files")
}

// =====================================================================
// SUIVI — non-dev client ops (manual, NOT mirrored from Linear)
// =====================================================================

enum ClientActionType {
  RELANCE
  LINK
  RDV
  OTHER
}

enum ClientActionStatus {
  TODO
  DONE
}

// ---------- ClientAction (manual to-do attached to a client) ----------
//
// Distinct from the Linear-mirrored `Task`. Used for follow-ups: invoice
// reminders (RELANCE, optionally linked to an invoice), sending links
// (LINK), meetings (RDV, optionally linked to a Meeting), or anything else.

model ClientAction {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type    ClientActionType   @default(OTHER)
  title   String
  link    String?
  notes   String?            @db.Text
  status  ClientActionStatus @default(TODO)
  dueDate DateTime?
  doneAt  DateTime?

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  meetingId String?
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([userId, status, dueDate])
  @@index([clientId])
  @@index([invoiceId])
  @@index([meetingId])
  @@map("client_actions")
}

// ---------- Meeting (Teams meeting log) ----------
//
// The meeting is created externally (Teams); we store its link, who attended,
// the real duration, and a markdown summary written by the user.

model Meeting {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  title           String
  teamsUrl        String?
  heldAt          DateTime
  durationMinutes Int      @default(0)
  participants    String[]
  summaryMd       String?  @db.Text

  actions ClientAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, heldAt(sort: Desc)])
  @@index([clientId, heldAt(sort: Desc)])
  @@map("meetings")
}

enum LinearSyncRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

/// Progress of one Linear sync run, polled by the client during a sync.
///
/// NOTE: this table also carries a PARTIAL UNIQUE INDEX that Prisma cannot
/// express here — `linear_sync_runs_userId_running_key` on ("userId") WHERE
/// status = 'RUNNING', enforcing at most one concurrent run per user. It is
/// defined only in 20260720120000_add_linear_sync_run/migration.sql, so
/// `migrate diff` reports it as permanent drift and `db push` will not create
/// it. Do not drop it to silence that drift.
model LinearSyncRun {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status LinearSyncRunStatus @default(RUNNING)

  totalMappings Int     @default(0)
  doneMappings  Int     @default(0)
  currentLabel  String?

  projectsUpserted Int @default(0)
  tasksUpserted    Int @default(0)

  errorMessage String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  updatedAt  DateTime  @updatedAt

  @@index([userId, startedAt])
  @@map("linear_sync_runs")
}
