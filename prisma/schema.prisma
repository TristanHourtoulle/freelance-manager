datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  clients       Client[]
  settings      UserSettings?
  notifications Notification[]
  expenses      Expense[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model UserSettings {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Billing defaults
  availableHoursPerMonth Int      @default(140)
  monthlyRevenueTarget   Decimal  @default(0) @db.Decimal(10, 2)
  defaultCurrency        String   @default("EUR")
  defaultPaymentDays     Int      @default(30)
  defaultRate            Decimal  @default(0) @db.Decimal(10, 2)

  // Notification preferences (JSON: { billingReminder: true, inactiveClient: true, ... })
  notificationPrefs      Json?

  // Linear integration (AES-256-GCM encrypted)
  linearApiTokenEncrypted Bytes?
  linearApiTokenIv        Bytes?

  // Appearance
  theme                  String   @default("system")
  accentColor            String   @default("#2563eb")

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("user_settings")
}

// --- Business Domain ---

enum BillingMode {
  HOURLY
  DAILY
  FIXED
  FREE
}

enum Category {
  FREELANCE
  STUDY
  PERSONAL
  SIDE_PROJECT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

enum NotificationType {
  BILLING_REMINDER
  INACTIVE_CLIENT
  SYNC_ALERT
  IMPORT_SUMMARY
  PAYMENT_OVERDUE
}

enum ExpenseCategory {
  SUBSCRIPTION
  SOFTWARE
  HARDWARE
  TRAVEL
  OFFICE
  MARKETING
  LEGAL
  PROFESSIONAL
  PERSONAL
  ENTERTAINMENT
  OTHER
}

model Client {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  company     String?
  logo        String?
  billingMode BillingMode  @default(HOURLY)
  rate        Decimal      @default(0) @db.Decimal(10, 2)
  category    Category     @default(FREELANCE)
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  linearMappings LinearMapping[]
  taskOverrides  TaskOverride[]
  invoices       Invoice[]
  expenses       Expense[]

  @@index([userId])
  @@index([category])
  @@map("clients")
}

model LinearMapping {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // At least one of linearTeamId or linearProjectId is required (enforced at application layer via Zod)
  linearTeamId    String?
  linearProjectId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, linearProjectId])
  @@map("linear_mappings")
}

model TaskOverride {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  linearIssueId String    @unique
  toInvoice     Boolean   @default(false)
  invoiced      Boolean   @default(false)
  invoicedAt    DateTime?
  rateOverride  Decimal?  @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId])
  @@map("task_overrides")
}

model Invoice {
  id             String        @id @default(cuid())
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month          DateTime
  totalAmount    Decimal       @default(0) @db.Decimal(10, 2)
  status         InvoiceStatus @default(DRAFT)
  paymentDueDate DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  files InvoiceFile[]

  @@unique([clientId, month])
  @@index([clientId])
  @@map("invoices")
}

model InvoiceFile {
  id         String   @id @default(cuid())
  invoiceId  String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fileName   String
  fileSize   Int
  mimeType   String   @default("application/pdf")
  fileData   Bytes
  uploadedAt DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_files")
}

model Expense {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  category    ExpenseCategory @default(OTHER)
  description String
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  recurring   Boolean         @default(false)
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([date])
  @@map("expenses")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, type])
  @@map("notifications")
}
