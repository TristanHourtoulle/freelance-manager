datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  clients       Client[]
  settings      UserSettings?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model UserSettings {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableHoursPerMonth Int      @default(140)
  monthlyRevenueTarget   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("user_settings")
}

// --- Business Domain ---

enum BillingMode {
  HOURLY
  DAILY
  FIXED
  FREE
}

enum Category {
  FREELANCE
  STUDY
  PERSONAL
  SIDE_PROJECT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

model Client {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  company     String?
  billingMode BillingMode  @default(HOURLY)
  rate        Decimal      @default(0) @db.Decimal(10, 2)
  category    Category     @default(FREELANCE)
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  linearMappings LinearMapping[]
  taskOverrides  TaskOverride[]
  invoices       Invoice[]

  @@index([userId])
  @@index([category])
  @@map("clients")
}

model LinearMapping {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // At least one of linearTeamId or linearProjectId is required (enforced at application layer via Zod)
  linearTeamId    String?
  linearProjectId String?  @unique // One Linear project maps to exactly one client
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, linearTeamId])
  @@map("linear_mappings")
}

model TaskOverride {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  linearIssueId String    @unique
  toInvoice     Boolean   @default(false)
  invoiced      Boolean   @default(false)
  invoicedAt    DateTime?
  rateOverride  Decimal?  @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId])
  @@map("task_overrides")
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  month       DateTime
  totalAmount Decimal       @default(0) @db.Decimal(10, 2)
  status      InvoiceStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([clientId, month])
  @@index([clientId])
  @@map("invoices")
}
