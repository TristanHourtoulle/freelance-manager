# PostgreSQL connection string
# Production: include sslmode=require&connection_limit=1&pool_timeout=20&pgbouncer=true&application_name=freelance-manager
DATABASE_URL="postgresql://user:password@localhost:5432/freelance_manager"

# REQUIRED — generate with: openssl rand -hex 32
# Used by better-auth for session signing (256-bit minimum)
BETTER_AUTH_SECRET=""

# REQUIRED — generate with: openssl rand -hex 32
# Used to encrypt the Linear API token at rest (AES-256-GCM)
ENCRYPTION_KEY=""

# REQUIRED in production — full URL of the deployed app, used as better-auth trustedOrigin
# Defaults to http://localhost:3000 when running pnpm dev
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OPTIONAL — Linear integration (set per-user via the settings UI; this is the fallback for CLI/scripts)
LINEAR_API_TOKEN=""
LINEAR_WEBHOOK_SECRET=""
LINEAR_CACHE_TTL_SECONDS=

# OPTIONAL — set to 1 only when running behind Vercel/Cloudflare/nginx that strips
# client-supplied X-Forwarded-For headers; otherwise client IPs can be spoofed
TRUST_PROXY=

# OPTIONAL — when set, /api/health returns the detailed payload only to callers
# providing this exact value via X-Health-Key header (otherwise returns { ok: true })
HEALTH_KEY=

# OPTIONAL — protects /api/cron/* endpoints
CRON_SECRET=
